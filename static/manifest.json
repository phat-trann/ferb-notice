{
  "manifest_version": 3,
  "name": "FerbNotice",
  "description": "FerbNotice reminds you to check in, tracks your workday, and reminds you to checkout. Made by Ferb.",
  "version": "1.0.0",
  "permissions": ["storage", "tabs", "alarms", "scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "FerbNotice • Made by Ferb",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
